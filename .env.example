OPENAI_BASE_URL=http://127.0.0.1:12345/v1
OPENAI_API_KEY=smartisan
OPENAI_MODEL=Qwen3.6-27B-Omnimerge-v4-MLX-4bit

# Local publishing. Set this after creating the GitHub repository.
GIT_REMOTE=git@github.com-arix:arixbit/ai-daily-brief.git

# X API publishing. Create an X Developer app with OAuth 2.0 enabled,
# Read and write permission, and callback URL:
# http://127.0.0.1:8787/callback
X_CLIENT_ID=
# Optional. Only set this if the X app is configured as a confidential client.
X_CLIENT_SECRET=
X_REDIRECT_URI=http://127.0.0.1:8787/callback
X_TOKEN_PATH=/Users/arix/.hermes/x-api-token.json
